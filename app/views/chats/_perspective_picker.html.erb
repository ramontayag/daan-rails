<%# app/views/chats/_perspective_picker.html.erb %>
<form action="<%= chat_path %>" method="get" class="px-4 py-2 flex gap-1">
  <select name="perspective"
          data-testid="perspective-picker"
          onchange="this.form.requestSubmit()"
          class="flex-1 bg-gray-800 text-white text-sm rounded px-2 py-1 border border-gray-600 focus:outline-none focus:ring-1 focus:ring-blue-400">
    <option value="me" <%= "selected" if perspective_name == "me" %>>Me (Human)</option>
    <% picker_agents = (@agents + [ @perspective_agent ]).compact.uniq(&:name) %>
    <% picker_agents.each do |agent| %>
      <option value="<%= agent.name %>" <%= "selected" if perspective_name == agent.name %>>
        <%= agent.display_name %>
      </option>
    <% end %>
  </select>
  <button type="submit" class="text-xs text-gray-400 hover:text-white px-1">Go</button>
</form>
