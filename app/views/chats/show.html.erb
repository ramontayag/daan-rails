<div class="flex h-screen" data-testid="chat-layout">
  <%= render SidebarComponent.new(current_perspective: perspective_name, current_agent: @agent) %>
  <div class="flex flex-1 overflow-hidden">
    <%= render ThreadListComponent.new(agent: @agent, chats: @chats, readonly: perspective_name != "me") %>
  </div>
</div>
