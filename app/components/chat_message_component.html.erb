<% if message.tool_calls.any? %>
  <% if message.content.present? %>
    <%= render MessageComponent.new(role: "assistant", body: message.content,
                                   dom_id: "message_#{message.id}",
                                   sender_name: sender_name,
                                   return_to_uri: return_to_uri) %>
  <% end %>
  <% unless hide_tools %>
    <% message.tool_calls.each do |tool_call| %>
      <%= render ToolCallComponent.new(tool_call: tool_call, result: results[tool_call.id], agent_display_name: agent_display_name) %>
    <% end %>
  <% end %>
<% else %>
  <%= render MessageComponent.new(role: message.role, body: message.content,
                                 dom_id: "message_#{message.id}",
                                 sender_name: sender_name, message: message,
                                 return_to_uri: return_to_uri) %>
<% end %>
