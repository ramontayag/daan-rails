<div data-testid="compose-bar" class="border-t p-4">
  <% if readonly %>
    <p class="text-sm text-gray-400 italic text-center">read-only — viewing another agent's perspective</p>
  <% else %>
    <div data-controller="auto-resize-textarea">
      <%= form_with url: action, method: :post, local: false, class: "flex gap-2 items-end" do |f| %>
        <%= f.text_area :content, name: "message[content]",
            placeholder: "Message...",
            class: "flex-1 border rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500 resize-none overflow-y-auto",
            rows: 1,
            autofocus: autofocus,
            required: true,
            data: {
              testid: "message-input",
              "auto-resize-textarea-target": "textarea",
              action: "input->auto-resize-textarea#input paste->auto-resize-textarea#paste keydown->auto-resize-textarea#keydown"
            } %>
        <%= f.submit "Send",
            class: "bg-blue-500 hover:bg-blue-600 text-white px-4 py-2 rounded-lg cursor-pointer shrink-0",
            disable_with: "Sending...",
            data: { testid: "send-button" } %>
      <% end %>
    </div>
  <% end %>
</div>