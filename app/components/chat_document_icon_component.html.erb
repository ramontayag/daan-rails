<div id="chat_documents_icon_<%= chat.id %>" class="relative inline-flex items-center">
  <% if has_documents? %>
    <div data-controller="popover" class="flex items-center" data-action="click@document->popover#close">
      <button type="button"
              data-action="popover#toggle"
              class="inline-flex items-center gap-1 text-gray-400 hover:text-gray-600 cursor-pointer">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
        </svg>
        <span id="chat_documents_count_<%= chat.id %>" class="text-xs"><%= document_count %></span>
      </button>
      <div data-popover-target="panel"
           class="hidden absolute top-full right-0 mt-1 w-52 py-1 bg-white border border-gray-200 rounded shadow-lg z-50 text-gray-700">
        <div id="chat_documents_list_<%= chat.id %>">
          <% documents.each do |doc| %>
            <div id="chat_document_<%= doc.id %>" class="px-3 py-1.5 text-xs">
              <%= link_to doc.title,
                          document_path(doc, return_to_uri: chat_thread_path(chat)),
                          class: "hover:text-blue-600 block",
                          data: { turbo_frame: "_top" } %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>
</div>
