<li data-testid="thread-list-item" class="border-b border-gray-100 <%= open ? 'bg-blue-50' : 'hover:bg-gray-50' %>">
  <%= link_to chat_thread_path(chat), class: "block px-4 py-3" do %>
    <div class="prose prose-sm max-w-none line-clamp-2 text-gray-900" data-controller="syntax-highlight">
      <%= preview_text %>
    </div>
    <div class="flex items-center gap-3 mt-1">
      <span class="text-xs text-gray-400"><%= timestamp %></span>
      <span class="text-xs text-blue-600"><%= "#{reply_count} #{"reply".pluralize(reply_count)}" %></span>
    </div>
  <% end %>
</li>
