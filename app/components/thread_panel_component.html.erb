<div data-testid="thread-panel" class="flex flex-col h-full">
  <div class="flex items-center justify-between px-4 py-2 border-b border-gray-200">
    <div class="flex items-center gap-2 md:hidden">
      <button data-action="click->sidebar#toggle"
              class="p-1 rounded hover:bg-gray-100 text-gray-500">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
      <%= link_to "← Back", chat_agent_path(chat.agent), class: "text-sm text-blue-600", data: { turbo_frame: "_top" } %>
    </div>
    <div class="flex items-center gap-3 ml-auto">
      <%= render ChatCostComponent.new(chat: chat) %>
      <%= render ChatDocumentIconComponent.new(chat: chat) %>
      <% if chat.chat_steps.any? %>
        <%= link_to chat_thread_path(chat, show_tasks: show_tasks ? "0" : "1"),
                    class: "text-gray-400 hover:text-gray-600",
                    title: show_tasks ? "Hide steps" : "Show steps",
                    data: { turbo_frame: "thread_panel" } do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
          </svg>
        <% end %>
      <% end %>
      <%= link_to chat_thread_path(chat, show_tools: hide_tools ? "1" : "0"),
                  class: "inline-flex #{hide_tools ? 'text-gray-300 hover:text-gray-500' : 'text-gray-800 hover:text-black'}",
                  title: hide_tools ? "Show tools" : "Hide tools",
                  data: { turbo_frame: "thread_panel" } do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17 17.25 21A2.652 2.652 0 0 0 21 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 1 1-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 0 0 4.486-6.336l-3.276 3.277a3.004 3.004 0 0 1-2.25-2.25l3.276-3.276a4.5 4.5 0 0 0-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085m-1.745 1.437L5.909 7.5H4.5L2.25 3.75l1.5-1.5L7.5 4.5v1.409l4.26 4.26m-1.745 1.437 1.745-1.437m6.615 8.206L15.75 15.75M4.867 19.125h.008v.008h-.008v-.008Z"/>
        </svg>
      <% end %>
      <%= link_to chat_agent_path(chat.agent),
                  class: "hidden md:flex items-center justify-center w-6 h-6 rounded hover:bg-gray-100 text-gray-400 hover:text-gray-600",
                  title: "Close",
                  data: { turbo_frame: "_top" } do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      <% end %>
    </div>
  </div>
  <%= render ChatStepPanelComponent.new(chat: chat, show_tasks: show_tasks) %>
<div class="flex-1 overflow-y-auto p-4" data-controller="scroll-to-bottom">
    <%= helpers.turbo_stream_from "chat_#{chat.id}" %>
    <div id="messages">
      <% chat_messages.each do |message| %>
        <%= render ChatMessageComponent.new(message: message, results: tool_results, hide_tools: hide_tools) %>
      <% end %>
    </div>
    <div id="typing_indicator"></div>
  </div>
  <%= render ComposeBarComponent.new(action: chat_thread_messages_path(chat), readonly: readonly, input_id: "thread-panel-message-input") %>
</div>