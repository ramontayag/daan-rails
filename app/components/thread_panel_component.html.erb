<div data-testid="thread-panel" class="flex flex-col h-full">
  <%= render ThreadPanelHeaderComponent.new(chat: chat, show_tasks: show_tasks, hide_tools: hide_tools) %>
  <%= render ChatStepPanelComponent.new(chat: chat, show_tasks: show_tasks) %>
  <div class="flex-1 overflow-y-auto p-4" data-controller="scroll-to-bottom">
    <%= helpers.turbo_stream_from "chat_#{chat.id}" %>
    <div id="messages">
      <%= render ChatMessageComponent.with_collection(chat_messages, results: tool_results, hide_tools: hide_tools) %>
    </div>
    <div id="agent_activity_indicator"></div>
  </div>
  <%= render ComposeBarComponent.new(action: chat_thread_messages_path(chat), readonly: readonly, input_id: "thread-panel-message-input") %>
</div>