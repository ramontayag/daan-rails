<div id="<%= dom_id %>"
     data-testid="message"
     data-role="<%= role %>"
     class="mb-4 flex gap-3">
  <div class="w-9 h-9 flex-shrink-0 rounded-full bg-gray-300 flex items-center justify-center text-xs font-bold text-gray-600 select-none">
    <%= initials %>
  </div>
  <div class="flex-1 min-w-0">
    <% if sender_name %>
      <div class="text-sm font-bold text-gray-900 mb-0.5"><%= sender_name %></div>
    <% end %>
    <div class="prose prose-sm max-w-none">
      <%= rendered_body %>
    </div>
    <% if message&.summary? %>
      <p class="mt-2 text-xs text-gray-400">
        <%= message.compacted_messages_count %> messages archived
      </p>
    <% end %>
  </div>
</div>
